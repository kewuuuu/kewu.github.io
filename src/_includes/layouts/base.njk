<!doctype html>
<html lang="zh-CN">
<head>
  {% set rootPrefix = page.url | pathToRoot %}
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or "博客" }}</title>
  <link rel="stylesheet" href="{{ rootPrefix }}assets/style.css">
  <script src="{{ rootPrefix }}assets/image-viewer.js" defer></script>
  <script src="{{ rootPrefix }}assets/post-layout.js" defer></script>
  <script src="{{ rootPrefix }}assets/code-block.js" defer></script>
</head>
<body>
  <header class="site-header">
    <div class="site-header-inner">
      <a class="site-brand" href="{{ rootPrefix }}index.html">Kewu Blog</a>
    </div>
  </header>
  {{ content | safe }}
</body>
</html>
