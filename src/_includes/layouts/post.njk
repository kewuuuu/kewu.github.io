---
layout: layouts/base.njk
---
{% from "partials/post-toc-tree.njk" import render as renderTocTree %}
{% set rootPrefix = page.url | pathToRoot %}
{% set currentTreeNode = collections.postTree.byUrl[page.url] %}
{% set currentPath = [] %}
{% if currentTreeNode and currentTreeNode.path %}
  {% set currentPath = currentTreeNode.path %}
{% endif %}
<main class="page-main page-post">
  {% set tocItems = content | extractToc(1, 4) %}
  {% set tocTree = tocItems | tocTree %}
  <div class="post-layout{% if tocItems and tocItems.length > 0 %} has-toc{% endif %}">
    {% if tocItems and tocItems.length > 0 %}
      <aside class="post-toc post-toc-left" aria-label="Article table of contents">
        <h2 class="post-toc-title">目录</h2>
        <nav class="post-toc-nav">
          {{ renderTocTree(tocTree) }}
        </nav>
      </aside>
      <div class="post-splitter post-splitter-left" role="separator" aria-orientation="vertical" aria-label="Resize left sidebar">
        <button class="post-splitter-toggle post-toggle-left" type="button" aria-expanded="true" aria-label="Collapse left sidebar">&lt;</button>
      </div>
    {% endif %}

    <section class="post-main-stack">
      {% if tocItems and tocItems.length > 0 %}
        <aside class="post-toc post-toc-inline" aria-label="Article table of contents">
          <h2 class="post-toc-title">目录</h2>
          <nav class="post-toc-nav">
            {{ renderTocTree(tocTree) }}
          </nav>
        </aside>
      {% endif %}
      <article class="post-article">
        {% if currentPath and currentPath.length > 0 %}
          <nav class="post-context-path" aria-label="Post hierarchy">
            <ol class="post-context-path-list">
              {% for pathNode in currentPath %}
                <li class="post-context-path-item post-context-path-item-{{ pathNode.kind }}">
                  {% if pathNode.url and not loop.last %}
                    <a href="{{ rootPrefix }}{{ pathNode.url | replace('/', '', 1) }}">{{ pathNode.title }}</a>
                  {% else %}
                    <span>{{ pathNode.title }}</span>
                  {% endif %}
                </li>
              {% endfor %}
            </ol>
          </nav>
        {% endif %}
        {% if title or description %}
          <header class="post-header">
            {% if title %}
              <h1 class="post-title">{{ title }}</h1>
            {% endif %}
            {% if description %}
              <p class="post-description">{{ description }}</p>
            {% endif %}
          </header>
        {% endif %}
        {{ content | safe }}
      </article>
    </section>

    <div class="post-splitter post-splitter-right" role="separator" aria-orientation="vertical" aria-label="Resize right sidebar">
      <button class="post-splitter-toggle post-toggle-right" type="button" aria-expanded="true" aria-label="Collapse right sidebar">&gt;</button>
    </div>

    <aside class="post-side" aria-label="Post extra panel">
      <div class="post-side-inner"></div>
    </aside>
  </div>
</main>
