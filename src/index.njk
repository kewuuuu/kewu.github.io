---
layout: layouts/home.njk
title: Home
permalink: /index.html
---
{% import "partials/content-tree.njk" as contentTree %}
{% set rootPrefix = page.url | pathToRoot %}

<section class="content-tree-panel content-tree-panel-home" id="article-tree" aria-label="Article tree">
  <div class="content-tree-heading-row">
    <h2 class="content-tree-heading">文章</h2>
    <div class="content-tree-toolbar" role="toolbar" aria-label="显示和排序设置">
      <button class="content-tree-toolbar-btn is-active" type="button" data-tree-action="toggle-view" data-tooltip="树形显示" aria-label="树形显示" aria-pressed="true">◫</button>
      <button class="content-tree-toolbar-btn" type="button" data-tree-action="toggle-sort-field" data-tooltip="按标题排序" aria-label="按标题排序" aria-pressed="false">A</button>
      <button class="content-tree-toolbar-btn" type="button" data-tree-action="toggle-sort-direction" data-tooltip="正序" aria-label="正序" aria-pressed="false">↑</button>
    </div>
  </div>
  {{ contentTree.render(collections.postTree.roots, page.url, [], true, rootPrefix) }}
</section>
